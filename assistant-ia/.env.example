# ZotoShop Assistant — variables d'environnement (copier en .env)

# Backend LLM du wrapper ask()
ZOTO_LLM=claude                 # claude | ollama
ANTHROPIC_API_KEY=sk-ant-...    # requis si ZOTO_LLM=claude
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1

# Comportement
ASSISTANT_TEMPERATURE=0.9       # haute = plus d'hallucinations (TP M6)
RAG_TOP_K=4

# Garde-fous : off = faille volontaire active (TP). on = corrige.
GUARDRAIL_SYSTEM_PROMPT_LEAK=off
GUARDRAIL_INJECTION_FILTER=off
GUARDRAIL_RAG_SANITIZE=off
GUARDRAIL_GROUNDING_STRICT=off
GUARDRAIL_PII_REDACT=off
GUARDRAIL_AUTHZ_ORDER=off
